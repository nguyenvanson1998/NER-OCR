# Google Document AI credentials
GOOGLE_APPLICATION_CREDENTIALS=credentials/credentials.json

# Google Document AI processors copied from the old Retrieval_System service
GOOGLE_AI_PROJECT_ID=
GOOGLE_AI_LOCATION=us
GOOGLE_AI_PROCESSOR_ID=
GOOGLE_AI_PROCESSOR_VERSION=rc
ENTERPRISE_PROCESSOR_ID=

# Optional Gemini extraction. If unset, the API returns heuristic extraction.
# Direct Gemini API key takes priority when GEMINI_API_KEY is set.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=90

# Vertex AI Gemini fallback uses GOOGLE_APPLICATION_CREDENTIALS plus project/location.
# Leave GEMINI_VERTEX_PROJECT_ID empty to reuse GOOGLE_AI_PROJECT_ID.
GEMINI_VERTEX_PROJECT_ID=
GEMINI_VERTEX_LOCATION=global
LLM_PROMPT_MODE=delta
LLM_DOCUMENT_MAX_OCR_CHARS=5000
LLM_CONTRACT_MAX_OCR_CHARS=10000
GEMINI_MAX_OUTPUT_TOKENS_DOCUMENT=1536
GEMINI_MAX_OUTPUT_TOKENS_CONTRACT=3072
LLM_MAX_OCR_CHARS=18000
LOCAL_EXTRACTION_ENABLED=true
# adaptive: chỉ gọi LLM khi rule thiếu/độ tin cậy thấp; always: luôn gọi; off: không gọi.
LLM_EXECUTION_MODE=adaptive
LLM_FALLBACK_ENABLED=true
LLM_ADAPTIVE_CONFIDENCE_THRESHOLD=0.72
LLM_ENTITY_EXTRACTION_ENABLED=true
LOCAL_CONFIDENCE_THRESHOLD=0.68
LLM_FALLBACK_MAX_CHARS=9000
# Tắt "thinking" trên Gemini 2.5 để giảm latency. Đặt > 0 nếu cần chất lượng cao hơn.
GEMINI_THINKING_BUDGET=0

# Optional Agribank internal matching for work_detail documents.
# If unset, OCR/extraction still works and project/task matching is skipped.
AGRIBANK_API_BASE_URL=https://agribank-be.opa.ai.vn/api/v1
AGRIBANK_API_KEY=
AGRIBANK_TIMEOUT_SECONDS=15
AGRIBANK_CACHE_TTL_SECONDS=300
AGRIBANK_CACHE_STALE_TTL_SECONDS=1800
PROJECT_MATCH_THRESHOLD=0.78
TASK_MATCH_THRESHOLD=0.55
LLM_MATCH_TIEBREAKER_MAX_GAP=0.15
LLM_MATCH_TIEBREAKER_TIMEOUT_SECONDS=15

# API
PORT=8000
KEEP_UPLOADS=false
OCR_CHUNK_SIZE=1000
OCR_MAX_PAGES_PER_REQUEST=14
OCR_MAX_PARALLEL_PARTS=2
DOCUMENT_AI_RPC_TIMEOUT_SECONDS=60
DOCUMENT_AI_RETRY_DEADLINE_SECONDS=75

# Fast V2 OCR. Start with vision_shadow, then canary and primary after enabling
# vision.googleapis.com and validating the quality metrics.
OCR_PROVIDER_MODE=vision_shadow
VISION_CANARY_PERCENT=10
VISION_OCR_TIMEOUT_SECONDS=4.2
VISION_MAX_PAGES_PER_REQUEST=5
VISION_MAX_PARALLEL_PARTS=2
VISION_MIN_WORD_CONFIDENCE=0.70
VISION_MIN_PAGE_TEXT_CHARS=20
VISION_CIRCUIT_BREAKER_SECONDS=300
VISION_CIRCUIT_FAILURE_THRESHOLD=2

# Durable V2 jobs / enrichment worker.
REDIS_URL=redis://localhost:6379/0
ENRICHMENT_JOB_TTL_SECONDS=86400
ENRICHMENT_WORKER_CONCURRENCY=4
ENRICHMENT_RECLAIM_IDLE_MS=60000
ENRICHMENT_RECLAIM_INTERVAL_SECONDS=30

# Structured pipeline performance logs.
PERF_SLOW_STAGE_MS=3000
PERF_SLOW_REQUEST_MS=15000
